# Resend — lead magnet email delivery
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# From address shown in the lead-magnet email.
# Use a verified domain in production (e.g. "Gio <gio@gio.gg>").
# Default during dev: "Gio <onboarding@resend.dev>".
RESEND_FROM=

# Public URL where the PDF lives. If empty, the email tells the user
# the PDF is on its way instead of including a download button.
LEAD_PDF_URL=

# Google Search Console verification token (renders the verification meta tag).
# Get it from Search Console → Settings → Ownership verification → HTML tag.
GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). If empty, GA is not loaded.
NEXT_PUBLIC_GA_ID=
